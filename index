import React, { useState, useMemo } from 'react';
import { 
  Calculator, 
  Building2, 
  Thermometer, 
  Wind, 
  Zap, 
  Flame, 
  Settings2, 
  Coins, 
  Layers,
  Info,
  CheckSquare,
  Square,
  TrendingUp,
  Leaf
} from 'lucide-react';

const App = () => {
  const [activeTab, setActiveTab] = useState('input');
  
  // Dane wejściowe
  const [pum, setPum] = useState(1000);
  const [ventilation, setVentilation] = useState('gravity'); // 'gravity' | 'mechanical'
  const [heatPumpUnitPower, setHeatPumpUnitPower] = useState(40); // Moc pojedynczej pompy w kaskadzie
  const [greenPremiumPerM2, setGreenPremiumPerM2] = useState(150); // O ile deweloper podniesie cene m2 za eko status

  // Stan kosztorysu (zaznaczone pozycje)
  const [selectedCostsHP, setSelectedCostsHP] = useState({
    units: true,
    cascade_logic: true,
    buffers: true,
    electric_upgrade: true,
    installation: true,
  });

  const [selectedCostsGas, setSelectedCostsGas] = useState({
    boilers: true,
    chimney: true,
    gas_connection: true,
    detection: true,
    installation: true,
  });

  // Stałe i wskaźniki
  const WT2021_DESCRIPTION = "Standard WT 2021: Okna 3-szybowe (U < 0.9), Izolacja ścian (styropian min. 15-20cm, U < 0.20), Izolacja dachu (U < 0.15).";
  
  // Wskaźniki zapotrzebowania q [W/m2]
  const qPerM2 = ventilation === 'gravity' ? 38 : 28;
  
  // Obliczenia mocy
  const totalHeatLoadKW = useMemo(() => (pum * qPerM2) / 1000, [pum, qPerM2]);

  // Wskaźniki EP (Energia Pierwotna) - Szacunkowe
  const epGas = ventilation === 'gravity' ? 78 : 68;
  const epHeatPump = ventilation === 'gravity' ? 55 : 42;

  // Kaskada pomp ciepła
  const numberOfPumps = Math.ceil(totalHeatLoadKW / heatPumpUnitPower);
  
  // Definicje kosztów szczegółowych (ceny uśrednione rynkowe)
  const costItemsHP = [
    { id: 'units', label: 'Jednostki Pomp Ciepła (Kaskada)', pricePerKw: 2000, description: 'Agregaty zewnętrzne i moduły hydrauliczne (stawka: 2000 zł/kW)' },
    { id: 'cascade_logic', label: 'Automatyka i sterowanie kaskadą', pricePerKw: 350, description: 'System zarządzania pracą wielu jednostek' },
    { id: 'buffers', label: 'Zasobniki buforowe i CWU', pricePerKw: 600, description: 'Magazynowanie energii i ciepłej wody' },
    { id: 'electric_upgrade', label: 'Przyłącze i modernizacja elektryczna', pricePerKw: 250, description: 'Większy przydział mocy pod sprężarki' },
    { id: 'installation', label: 'Montaż i uruchomienie', pricePerKw: 500, description: 'Prace instalacyjne i odbiór producenta' },
  ];

  const costItemsGas = [
    { id: 'boilers', label: 'Kotły kondensacyjne (Kaskada)', pricePerKw: 850, description: 'Wysokosprawne kotły gazowe' },
    { id: 'chimney', label: 'Systemy kominowe i spalinowe', pricePerKw: 250, description: 'Wkłady kwasoodporne i wyprowadzenie' },
    { id: 'gas_connection', label: 'Przyłącze gazowe i szafka', pricePerKw: 150, description: 'Projekt i wykonanie podejścia gazu' },
    { id: 'detection', label: 'System detekcji gazu i ppoż', pricePerKw: 100, description: 'Bezpieczeństwo w kotłowni' },
    { id: 'installation', label: 'Montaż i odbiór kominiarski', pricePerKw: 250, description: 'Prace instalacyjne i próby szczelności' },
  ];

  // Obliczenia sumarycznych kosztów
  const totalCostHP = useMemo(() => {
    return costItemsHP
      .filter(item => selectedCostsHP[item.id])
      .reduce((acc, item) => acc + (item.pricePerKw * totalHeatLoadKW), 0);
  }, [totalHeatLoadKW, selectedCostsHP]);

  const totalCostGas = useMemo(() => {
    return costItemsGas
      .filter(item => selectedCostsGas[item.id])
      .reduce((acc, item) => acc + (item.pricePerKw * totalHeatLoadKW), 0);
  }, [totalHeatLoadKW, selectedCostsGas]);

  // --- Analiza korzyści biznesowych ---
  const savedSpaceM2 = Math.ceil(pum / 200) + 12; // Szacunek: 12m2 kotłowni + oszczędność na szachtach
  const salesRevenueFromSavedSpace = savedSpaceM2 * 8000; // Przyjmując średnią cenę sprzedaży 8k/m2
  const greenMarketingProfit = pum * greenPremiumPerM2;
  const totalBenefitHP = salesRevenueFromSavedSpace + greenMarketingProfit;

  const toggleCostHP = (id) => setSelectedCostsHP(prev => ({ ...prev, [id]: !prev[id] }));
  const toggleCostGas = (id) => setSelectedCostsGas(prev => ({ ...prev, [id]: !prev[id] }));

  const renderTabContent = () => {
    switch (activeTab) {
      case 'input':
        return (
          <div className="space-y-4 md:space-y-6">
            <div className="bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-md">
              <div className="flex items-start md:items-center">
                <Info className="text-blue-500 mr-3 shrink-0" size={20} />
                <p className="text-xs md:text-sm text-blue-800">
                  <strong>Status techniczny:</strong> {WT2021_DESCRIPTION}
                </p>
              </div>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
              <div className="bg-white p-4 md:p-6 rounded-xl shadow-sm border border-gray-100">
                <label className="block text-sm font-medium text-gray-700 mb-2">Powierzchnia PUM (m²)</label>
                <div className="relative">
                  <Building2 className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" size={20} />
                  <input 
                    type="number" 
                    value={pum} 
                    onChange={(e) => setPum(Number(e.target.value))}
                    className="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all text-base"
                  />
                </div>
              </div>

              <div className="bg-white p-4 md:p-6 rounded-xl shadow-sm border border-gray-100">
                <label className="block text-sm font-medium text-gray-700 mb-2">Rodzaj wentylacji</label>
                <div className="flex flex-col sm:flex-row gap-2">
                  <button 
                    onClick={() => setVentilation('gravity')}
                    className={`flex-1 py-3 px-4 rounded-lg border transition-all flex items-center justify-center gap-2 text-sm font-semibold ${ventilation === 'gravity' ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-600 border-gray-300 hover:bg-gray-50'}`}
                  >
                    <Wind size={18} /> Grawitacyjna
                  </button>
                  <button 
                    onClick={() => setVentilation('mechanical')}
                    className={`flex-1 py-3 px-4 rounded-lg border transition-all flex items-center justify-center gap-2 text-sm font-semibold ${ventilation === 'mechanical' ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-600 border-gray-300 hover:bg-gray-50'}`}
                  >
                    <Settings2 size={18} /> Mechaniczna
                  </button>
                </div>
              </div>
            </div>

            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
              <div className="bg-gradient-to-br from-blue-600 to-indigo-700 p-5 md:p-6 rounded-2xl text-white shadow-lg flex flex-col justify-center">
                <div className="flex items-center gap-2 opacity-80 mb-1">
                  <Thermometer size={18} />
                  <span className="text-xs md:text-sm font-medium">Wskaźnik zapotrzebowania</span>
                </div>
                <div className="text-3xl md:text-4xl font-bold mb-1">{qPerM2} W/m²</div>
                <div className="text-[10px] md:text-xs opacity-80 italic">Szacunek na podstawie WT 2021</div>
              </div>

              <div className="bg-white p-5 md:p-6 rounded-2xl border-2 border-blue-100 shadow-sm flex flex-col justify-center">
                <div className="flex items-center gap-2 text-gray-500 mb-1">
                  <Zap size={18} className="text-blue-500" />
                  <span className="text-xs md:text-sm font-medium">Całkowita moc grzewcza</span>
                </div>
                <div className="text-3xl md:text-4xl font-bold text-gray-800">{totalHeatLoadKW.toFixed(1)} kW</div>
                <div className="text-[10px] md:text-xs text-gray-400">Zapotrzebowanie projektowe</div>
              </div>

              <div className="bg-white p-5 md:p-6 rounded-2xl border border-gray-100 shadow-sm space-y-3 md:space-y-4 sm:col-span-2 lg:col-span-1">
                <div>
                  <div className="flex justify-between text-[10px] font-bold mb-1 uppercase tracking-wider text-gray-400">
                    <span>Energia Pierwotna (EP)</span>
                    <span>kWh/(m²·rok)</span>
                  </div>
                  <div className="space-y-3">
                    <div className="flex items-center justify-between">
                      <span className="text-xs md:text-sm text-gray-600 flex items-center gap-1"><Zap size={14} className="text-blue-500" /> Pompa Ciepła</span>
                      <span className="font-bold text-green-600 text-sm md:text-base">~{epHeatPump}</span>
                    </div>
                    <div className="w-full bg-gray-100 rounded-full h-1.5">
                      <div className="bg-green-500 h-1.5 rounded-full" style={{width: `${(epHeatPump/100)*100}%`}}></div>
                    </div>
                    <div className="flex items-center justify-between">
                      <span className="text-xs md:text-sm text-gray-600 flex items-center gap-1"><Flame size={14} className="text-orange-500" /> Kocioł Gazowy</span>
                      <span className="font-bold text-red-500 text-sm md:text-base">~{epGas}</span>
                    </div>
                    <div className="w-full bg-gray-100 rounded-full h-1.5">
                      <div className="bg-red-400 h-1.5 rounded-full" style={{width: `${(epGas/100)*100}%`}}></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      case 'cascade':
        return (
          <div className="space-y-4 md:space-y-6">
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
              <div className="bg-white p-5 md:p-6 rounded-xl shadow-sm border border-gray-100">
                <h3 className="text-base md:text-lg font-semibold mb-4 flex items-center gap-2">
                  <Layers className="text-blue-600" size={20} /> Dobór urządzeń kaskady
                </h3>
                <div className="space-y-4">
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-2">Moc pojedynczej jednostki (kW)</label>
                    <input 
                      type="range" 
                      min="10" 
                      max="100" 
                      step="5"
                      value={heatPumpUnitPower} 
                      onChange={(e) => setHeatPumpUnitPower(Number(e.target.value))}
                      className="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue-600"
                    />
                    <div className="flex justify-between text-[10px] md:text-xs text-gray-500 mt-2">
                      <span>10 kW</span>
                      <span className="font-bold text-blue-600">{heatPumpUnitPower} kW</span>
                      <span>100 kW</span>
                    </div>
                  </div>
                </div>
              </div>

              <div className="bg-blue-600 p-5 md:p-6 rounded-xl shadow-lg text-white flex flex-col justify-center">
                <div className="text-xs opacity-80 mb-2 uppercase tracking-wide font-bold">Wymagana liczba jednostek</div>
                <div className="text-4xl md:text-5xl font-bold mb-3">{numberOfPumps} <span className="text-xl md:text-2xl font-normal">szt.</span></div>
                <p className="text-xs md:text-sm opacity-90 leading-relaxed">
                  Zalecana kaskada {numberOfPumps} urządzeń o mocy {heatPumpUnitPower} kW przy zapotrzebowaniu {totalHeatLoadKW.toFixed(1)} kW.
                </p>
                <div className="mt-4 pt-4 border-t border-blue-400 flex justify-between items-center text-xs md:text-sm">
                  <span className="opacity-80">Nadmiarowość:</span>
                  <span className="font-bold text-green-300">+{((numberOfPumps * heatPumpUnitPower) - totalHeatLoadKW).toFixed(1)} kW</span>
                </div>
              </div>
            </div>

            <div className="bg-white p-5 md:p-6 rounded-xl border border-gray-100">
              <h3 className="text-sm md:text-md font-semibold mb-4 text-blue-800 uppercase tracking-wider">Dlaczego warto wybrać Pompy Ciepła?</h3>
              <div className="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 text-[11px] md:text-sm">
                <div className="p-3 md:p-4 bg-blue-50 rounded-lg border border-blue-100 leading-relaxed">
                  <div className="font-bold mb-2 flex items-center gap-1 text-blue-700 uppercase text-xs"><Leaf size={14}/> Niska emisja</div>
                  Brak spalin na miejscu inwestycji eliminuje potrzebę budowy wysokich kominów i ogranicza smog. Inwestycja staje się "Zero Emission Ready", co podnosi jej prestiż.
                </div>
                <div className="p-3 md:p-4 bg-blue-50 rounded-lg border border-blue-100 leading-relaxed">
                  <div className="font-bold mb-2 flex items-center gap-1 text-blue-700 uppercase text-xs"><Zap size={14}/> Bezpieczeństwo</div>
                  Brak instalacji gazowej wewnątrz budynku to mniejsze ryzyko wybuchu i zatrucia czadem. Upraszcza to procedury odbiorowe ppoż i obniża koszty ubezpieczenia obiektu.
                </div>
                <div className="p-3 md:p-4 bg-blue-50 rounded-lg border border-blue-100 leading-relaxed">
                  <div className="font-bold mb-2 flex items-center gap-1 text-blue-700 uppercase text-xs"><TrendingUp size={14}/> Wartość PUM</div>
                  Rezygnacja z kotłowni gazowej pozwala na odzyskanie metrów kwadratowych, które można przeznaczyć na lokale mieszkalne lub komórki lokatorskie, zwiększając zysk.
                </div>
              </div>
            </div>
          </div>
        );
      case 'costs':
        return (
          <div className="space-y-6">
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8">
              {/* Sekcja Pompy Ciepła */}
              <div className="space-y-4">
                <div className="flex items-center gap-2 mb-2">
                  <Zap className="text-green-600 shrink-0" size={24} />
                  <h3 className="text-lg md:text-xl font-bold">System Pompy Ciepła</h3>
                </div>
                <div className="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                  <div className="p-3 md:p-4 bg-gray-50 border-b border-gray-200 flex justify-between items-center text-[10px] md:text-xs font-bold text-gray-600 uppercase tracking-wider">
                    <span>Pozycja</span>
                    <span>Koszt netto</span>
                  </div>
                  <div className="divide-y divide-gray-100">
                    {costItemsHP.map((item) => (
                      <div 
                        key={item.id} 
                        className={`p-3 md:p-4 flex items-start gap-3 transition-colors cursor-pointer hover:bg-gray-50 ${selectedCostsHP[item.id] ? 'bg-white' : 'bg-gray-50 opacity-60'}`}
                        onClick={() => toggleCostHP(item.id)}
                      >
                        <div className="mt-1 shrink-0">
                          {selectedCostsHP[item.id] ? <CheckSquare className="text-blue-600" size={18} /> : <Square className="text-gray-300" size={18} />}
                        </div>
                        <div className="flex-1 min-w-0">
                          <div className="text-xs md:text-sm font-bold truncate">{item.label}</div>
                          <div className="text-[10px] md:text-xs text-gray-500 line-clamp-1">{item.description}</div>
                        </div>
                        <div className="text-right shrink-0">
                          <div className="text-xs md:text-sm font-bold">{(item.pricePerKw * totalHeatLoadKW).toLocaleString()} PLN</div>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div className="p-5 md:p-6 bg-green-600 text-white">
                    <div className="text-[10px] uppercase opacity-80 mb-1 font-bold">Inwestycja HP</div>
                    <div className="text-2xl md:text-3xl font-black">{totalCostHP.toLocaleString()} PLN</div>
                    <div className="text-[10px] mt-1 opacity-80">{(totalCostHP / pum).toFixed(0)} PLN/m² PUM</div>
                  </div>
                </div>
              </div>

              {/* Sekcja Kotłowni Gazowej */}
              <div className="space-y-4">
                <div className="flex items-center gap-2 mb-2">
                  <Flame className="text-orange-600 shrink-0" size={24} />
                  <h3 className="text-lg md:text-xl font-bold">Kotłownia Gazowa</h3>
                </div>
                <div className="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                  <div className="p-3 md:p-4 bg-gray-50 border-b border-gray-200 flex justify-between items-center text-[10px] md:text-xs font-bold text-gray-600 uppercase tracking-wider">
                    <span>Pozycja</span>
                    <span>Koszt netto</span>
                  </div>
                  <div className="divide-y divide-gray-100">
                    {costItemsGas.map((item) => (
                      <div 
                        key={item.id} 
                        className={`p-3 md:p-4 flex items-start gap-3 transition-colors cursor-pointer hover:bg-gray-50 ${selectedCostsGas[item.id] ? 'bg-white' : 'bg-gray-50 opacity-60'}`}
                        onClick={() => toggleCostGas(item.id)}
                      >
                        <div className="mt-1 shrink-0">
                          {selectedCostsGas[item.id] ? <CheckSquare className="text-orange-600" size={18} /> : <Square className="text-gray-300" size={18} />}
                        </div>
                        <div className="flex-1 min-w-0">
                          <div className="text-xs md:text-sm font-bold truncate">{item.label}</div>
                          <div className="text-[10px] md:text-xs text-gray-500 line-clamp-1">{item.description}</div>
                        </div>
                        <div className="text-right shrink-0">
                          <div className="text-xs md:text-sm font-bold">{(item.pricePerKw * totalHeatLoadKW).toLocaleString()} PLN</div>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div className="p-5 md:p-6 bg-orange-600 text-white">
                    <div className="text-[10px] uppercase opacity-80 mb-1 font-bold">Inwestycja GAZ</div>
                    <div className="text-2xl md:text-3xl font-black">{totalCostGas.toLocaleString()} PLN</div>
                    <div className="text-[10px] mt-1 opacity-80">{(totalCostGas / pum).toFixed(0)} PLN/m² PUM</div>
                  </div>
                </div>
              </div>
            </div>

            {/* Analiza Wartości Dodanej */}
            <div className="bg-indigo-900 text-white p-5 md:p-8 rounded-2xl shadow-2xl mt-6 md:mt-8 border-t-4 border-yellow-400">
              <div className="flex items-center gap-3 mb-6">
                <TrendingUp className="text-yellow-400 shrink-0" size={28} md={32} />
                <h3 className="text-lg md:text-2xl font-black uppercase italic tracking-tighter">Analiza Wartości Dodanej (Premium)</h3>
              </div>
              
              <div className="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8">
                <div className="space-y-4 md:space-y-6">
                  <div className="bg-white/10 p-4 md:p-5 rounded-xl border border-white/20">
                    <h4 className="text-yellow-400 font-bold text-sm md:text-base mb-3 flex items-center gap-2">
                      <Layers size={18} /> Zysk powierzchni PUM
                    </h4>
                    <p className="text-[11px] md:text-sm text-indigo-100 mb-4 leading-relaxed">
                      Rezygnacja z szachtów i murowanej kotłowni zwalnia cenną powierzchnię sprzedażową.
                    </p>
                    <div className="flex justify-between items-end border-t border-white/10 pt-4 gap-4">
                      <div>
                        <div className="text-[10px] opacity-60">Odzyskany PUM</div>
                        <div className="text-lg md:text-2xl font-bold">{savedSpaceM2} m²</div>
                      </div>
                      <div className="text-right">
                        <div className="text-[10px] opacity-60">Wartość rynkowa</div>
                        <div className="text-lg md:text-2xl font-bold text-green-400">~{salesRevenueFromSavedSpace.toLocaleString()} zł</div>
                      </div>
                    </div>
                  </div>

                  <div className="bg-white/10 p-4 md:p-5 rounded-xl border border-white/20">
                    <h4 className="text-green-400 font-bold text-sm md:text-base mb-3 flex items-center gap-2">
                      <Leaf size={18} /> Strategia "Green Premium"
                    </h4>
                    <label className="text-[10px] opacity-60 block mb-2 uppercase font-bold tracking-wide text-indigo-200">Wzrost ceny (PLN/m² PUM):</label>
                    <input 
                      type="number" 
                      value={greenPremiumPerM2}
                      onChange={(e) => setGreenPremiumPerM2(Number(e.target.value))}
                      className="bg-indigo-800 border border-indigo-700 rounded px-3 py-2 text-white w-full mb-4 text-sm"
                    />
                    <div className="flex justify-between items-end border-t border-white/10 pt-4">
                      <div>
                        <div className="text-[10px] opacity-60 uppercase font-bold text-indigo-200">Dodatkowy przychód</div>
                        <div className="text-lg md:text-2xl font-bold text-green-400">+{greenMarketingProfit.toLocaleString()} zł</div>
                      </div>
                    </div>
                  </div>
                </div>

                <div className="bg-indigo-800/50 p-6 md:p-8 rounded-2xl flex flex-col justify-center border-2 border-yellow-400/30">
                  <div className="text-center space-y-2">
                    <div className="text-[10px] md:text-xs uppercase tracking-widest text-indigo-200 font-bold">Finalny bilans biznesowy wyboru HP</div>
                    <div className="text-4xl md:text-6xl font-black text-yellow-400 italic">
                      {(totalBenefitHP - (totalCostHP - totalCostGas)).toLocaleString()} <span className="text-xl md:text-3xl">PLN</span>
                    </div>
                    <div className="text-[9px] md:text-xs text-indigo-200 opacity-60 italic pt-4">
                      *Bilans po odjęciu wyższego kosztu technologii od zysku z odzyskanego PUM i marki "Eko".
                    </div>
                  </div>
                  
                  <div className="mt-8 space-y-3">
                    <div className="flex items-center justify-between text-[11px] md:text-sm py-2 border-b border-white/10">
                      <span className="opacity-80">Różnica CAPEX (koszt urządzeń)</span>
                      <span className="text-red-400 font-bold">-{ (totalCostHP - totalCostGas).toLocaleString() } zł</span>
                    </div>
                    <div className="flex items-center justify-between text-[11px] md:text-sm py-2 border-b border-white/10">
                      <span className="opacity-80">Dodatkowy PUM ze sprzedaży</span>
                      <span className="text-green-400 font-bold">+{ salesRevenueFromSavedSpace.toLocaleString() } zł</span>
                    </div>
                    <div className="flex items-center justify-between text-[11px] md:text-sm py-2">
                      <span className="opacity-80">Przychód z certyfikatu "Eko"</span>
                      <span className="text-green-400 font-bold">+{ greenMarketingProfit.toLocaleString() } zł</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      default:
        return null;
    }
  };

  return (
    <div className="min-h-screen bg-gray-50 font-sans text-gray-900 overflow-x-hidden">
      <div className="max-w-5xl mx-auto px-4 py-6 md:py-10">
